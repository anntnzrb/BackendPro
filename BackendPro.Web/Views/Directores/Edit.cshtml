@model BackendPro.Web.Models.DirectorFormViewModel
@{
    ViewData["Title"] = "Editar director";
}

<section class="toolbar">
    <div>
        <h2><i class="fas fa-user-pen"></i> Editar director</h2>
        <p>Modifica la información del director seleccionado.</p>
    </div>
    <div class="toolbar-actions">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index"><i class="fas fa-arrow-left me-2"></i>Volver</a>
    </div>
</section>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="mt-3">
    <partial name="_Form" model="Model" />
    <div class="d-flex justify-content-between">
        <a class="btn btn-outline-secondary" asp-action="Index"><i class="fas fa-ban me-2"></i>Cancelar</a>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Guardar cambios</button>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
