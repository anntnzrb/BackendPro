@using System.Collections.Generic
@using System.Linq
@model IEnumerable<BackendPro.Core.DTOs.PeliculaDto>
@{
    ViewData["Title"] = "Películas";
    var hasPeliculas = Model.Any();
}

<section class="toolbar">
    <div>
        <h2><i class="fas fa-film"></i> Catálogo de películas</h2>
        <p>Consulta y administra todas las producciones registradas en el sistema.</p>
    </div>
    <div class="toolbar-actions">
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus me-2"></i>Nueva película</a>
        <button class="btn btn-outline-secondary btn-sm" type="button"><i class="fas fa-arrow-down-wide-short me-2"></i>Ordenar</button>
        <button class="btn btn-outline-secondary btn-sm" type="button"><i class="fas fa-filter me-2"></i>Filtrar</button>
    </div>
</section>

@if (!hasPeliculas)
{
    @await Html.PartialAsync("_EmptyState", new BackendPro.Web.Models.EmptyStateViewModel
    {
        Icon = "fas fa-film",
        Title = "No hay películas registradas",
        Description = "Cuando agregues nuevas películas al catálogo podrás visualizarlas y consultarlas desde este panel.",
        ActionText = "Ir al catálogo",
        ActionUrl = Url.Action("Index", "Peliculas")
    })
}
else
{
    <div class="card-grid">
        @foreach (var pelicula in Model)
        {
            var actores = pelicula.Actores?.Where(a => !string.IsNullOrWhiteSpace(a.Nombre)).Take(3).Select(a => a.Nombre).ToList() ?? new List<string>();
            var sinopsis = string.IsNullOrWhiteSpace(pelicula.Sinopsis)
                ? "Sin sinopsis disponible."
                : (pelicula.Sinopsis.Length > 160 ? pelicula.Sinopsis[..160] + "…" : pelicula.Sinopsis);
            <article class="movie-card">
                <div class="movie-poster">
                    @if (!string.IsNullOrWhiteSpace(pelicula.ImagenUrl))
                    {
                        <img src="@pelicula.ImagenUrl" alt="@pelicula.Titulo" />
                    }
                    else
                    {
                        <i class="fas fa-clapperboard"></i>
                    }
                    <div class="movie-overlay"></div>
                </div>
                <div class="movie-card-content">
                    <div class="d-flex flex-column gap-2">
                        <h3 class="h5 mb-0">@pelicula.Titulo</h3>
                        <p class="text-muted mb-0">@sinopsis</p>
                    </div>
                    <div class="chip-group">
                        <span class="chip"><i class="fas fa-tag me-1"></i>@pelicula.Genero.Nombre</span>
                        <span class="chip"><i class="fas fa-user-tie me-1"></i>@pelicula.Director.Nombre</span>
                    </div>
                    <div class="meta-list">
                        <span><i class="fas fa-clock"></i>@pelicula.Duracion minutos</span>
                        <span><i class="fas fa-calendar"></i>@pelicula.FechaEstreno.ToString("dd/MM/yyyy")</span>
                        @if (actores.Any())
                        {
                            <span><i class="fas fa-users"></i>@string.Join(", ", actores)</span>
                        }
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-primary btn-sm" asp-action="Details" asp-route-id="@pelicula.Id">
                            <i class="fas fa-eye me-2"></i>Ver detalles
                        </a>
                        <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@pelicula.Id">
                            <i class="fas fa-pen me-2"></i>Editar
                        </a>
                        <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@pelicula.Id">
                            <i class="fas fa-trash me-2"></i>Eliminar
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>
}
