@model IEnumerable<BackendPro.Core.DTOs.PeliculaDto>
@{
    ViewData["Title"] = "Películas";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1><i class="fas fa-film"></i> Catálogo de Películas</h1>
            <p class="text-muted">Todas las películas del sistema</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle fa-2x mb-3"></i>
                    <h4>No hay películas registradas</h4>
                    <p>El sistema no contiene películas aún. Los datos mostrarán aquí cuando agregues películas al catálogo.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var pelicula in Model)
            {
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(pelicula.ImagenUrl))
                        {
                            <img src="@pelicula.ImagenUrl" class="card-img-top" alt="@pelicula.Titulo" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="fas fa-film fa-3x text-white"></i>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@pelicula.Titulo</h5>
                            <p class="card-text text-muted small">
    @{
        var sinopsis = pelicula.Sinopsis.Length > 100 ? pelicula.Sinopsis.Substring(0, 100) + "..." : pelicula.Sinopsis;
    }
    @sinopsis
</p>
                            
                            <div class="mt-auto">
                                <p class="mb-1"><strong>Duración:</strong> @pelicula.Duracion minutos</p>
                                <p class="mb-1"><strong>Estreno:</strong> @pelicula.FechaEstreno.ToString("dd/MM/yyyy")</p>
                                <p class="mb-1"><strong>Género:</strong> @pelicula.Genero.Nombre</p>
                                <p class="mb-2"><strong>Director:</strong> @pelicula.Director.Nombre</p>
                                
                                <div class="btn-group w-100" role="group">
                                    <a href="@Url.Action("Details", "Peliculas", new { id = pelicula.Id })" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-eye"></i> Detalles
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
