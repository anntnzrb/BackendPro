@model IEnumerable<BackendPro.Core.DTOs.GeneroDto>
@{
    ViewData["Title"] = "Géneros";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1><i class="fas fa-tags"></i> Géneros Cinematográficos</h1>
            <p class="text-muted">Todos los géneros disponibles en el sistema</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle fa-2x mb-3"></i>
                    <h4>No hay géneros registrados</h4>
                    <p>El sistema no contiene géneros aún. Los datos mostrarán aquí cuando agregues géneros al catálogo.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var genero in Model)
            {
                <div class="col-md-4 col-sm-6 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-tag text-primary"></i> @genero.Nombre
                            </h5>
                            @if (!string.IsNullOrEmpty(genero.Descripcion))
                            {
                                <p class="card-text text-muted">@genero.Descripcion</p>
                            }
                            
                            <div class="btn-group" role="group">
                                <a href="@Url.Action("Details", "Generos", new { id = genero.Id })" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-eye"></i> Detalles
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
